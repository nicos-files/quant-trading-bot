{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "decision_intel.comparison_metrics.schema.json",
  "title": "Comparison Metrics",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "reader_min_version",
    "run_id",
    "baseline",
    "candidate",
    "comparison_metrics"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "reader_min_version": { "type": "string", "const": "1.0.0" },
    "run_id": { "type": "string" },
    "baseline": {
      "type": "object",
      "additionalProperties": false,
      "required": ["strategy_id", "variant_id"],
      "properties": {
        "strategy_id": { "type": "string" },
        "variant_id": { "type": ["string", "null"] }
      }
    },
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["strategy_id", "variant_id"],
      "properties": {
        "strategy_id": { "type": "string" },
        "variant_id": { "type": ["string", "null"] }
      }
    },
    "comparison_metrics": {
      "type": "object",
      "additionalProperties": false,
      "patternProperties": {
        "^[A-Za-z0-9_.-]+$": {
          "type": "object",
          "additionalProperties": false,
          "required": ["baseline", "candidate", "delta"],
          "properties": {
            "baseline": { "type": ["number", "null"] },
            "candidate": { "type": ["number", "null"] },
            "delta": { "type": ["number", "null"] }
          }
        }
      }
    }
  }
}
