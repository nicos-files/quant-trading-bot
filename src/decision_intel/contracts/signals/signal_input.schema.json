{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "decision_intel.signal_input.schema.json",
  "title": "Signal Input",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "reader_min_version", "horizon", "signals"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "reader_min_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "horizon": {
      "type": "string",
      "enum": ["SHORT", "MEDIUM", "LONG"]
    },
    "signals": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["asset_id", "signal"],
        "properties": {
          "asset_id": { "type": "string" },
          "signal": { "type": "number" },
          "score": { "type": "number" }
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
