{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "decision_intel.run_manifest.schema.json",
  "title": "Run Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "reader_min_version",
    "run_id",
    "status",
    "timestamps",
    "config",
    "data_snapshot_ids",
    "artifact_index",
    "skips"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "reader_min_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "run_id": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "CREATED",
        "RUNNING",
        "SUCCESS",
        "FAILED",
        "PARTIAL",
        "SKIPPED"
      ]
    },
    "timestamps": {
      "type": "object",
      "additionalProperties": false,
      "required": ["created_at"],
      "properties": {
        "created_at": { "type": "string", "format": "date-time" },
        "started_at": { "type": ["string", "null"], "format": "date-time" },
        "completed_at": { "type": ["string", "null"], "format": "date-time" }
      }
    },
    "config": {
      "type": "object",
      "additionalProperties": false,
      "required": ["snapshot_path"],
      "properties": {
        "snapshot_path": { "type": "string" },
        "hash": { "type": "string" }
      }
    },
    "data_snapshot_ids": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "artifact_index": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "type", "path", "schema_version"],
        "properties": {
          "name": { "type": "string" },
          "type": { "type": "string" },
          "path": { "type": "string" },
          "schema_version": { "type": "string" },
          "content_hash": { "type": ["string", "null"] }
        }
      }
    },
    "skips": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "reason"],
        "properties": {
          "code": { "type": "string" },
          "reason": { "type": "string" }
        }
      }
    },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["error_code", "message"],
      "properties": {
        "error_code": { "type": "string" },
        "message": { "type": "string" }
      }
    }
  }
}
