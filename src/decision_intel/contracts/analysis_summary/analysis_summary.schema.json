{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "decision_intel.analysis_summary.schema.json",
  "title": "Analysis Summary",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "reader_min_version",
    "run_id",
    "baseline",
    "candidate",
    "summary"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "reader_min_version": { "type": "string", "const": "1.0.0" },
    "run_id": { "type": "string" },
    "baseline": {
      "type": "object",
      "additionalProperties": false,
      "required": ["strategy_id", "variant_id"],
      "properties": {
        "strategy_id": { "type": "string" },
        "variant_id": { "type": ["string", "null"] }
      }
    },
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["strategy_id", "variant_id"],
      "properties": {
        "strategy_id": { "type": "string" },
        "variant_id": { "type": ["string", "null"] }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_metrics",
        "compared_metrics",
        "null_delta_count",
        "null_delta_metrics"
      ],
      "properties": {
        "total_metrics": { "type": "integer", "minimum": 0 },
        "compared_metrics": { "type": "integer", "minimum": 0 },
        "null_delta_count": { "type": "integer", "minimum": 0 },
        "null_delta_metrics": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "pattern": "^[A-Za-z0-9_.-]+$" }
        }
      }
    }
  }
}
