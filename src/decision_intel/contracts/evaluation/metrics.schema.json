{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "decision_intel.metrics.schema.json",
  "title": "Evaluation Metrics",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "reader_min_version",
    "run_id",
    "strategy_id",
    "horizon",
    "metrics"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "reader_min_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "run_id": { "type": "string" },
    "strategy_id": { "type": "string" },
    "variant_id": { "type": ["string", "null"] },
    "horizon": { "type": "string", "enum": ["SHORT", "MEDIUM", "LONG"] },
    "metrics": {
      "type": "object",
      "additionalProperties": { "type": "number" }
    }
  }
}
